# Copy to .env for local dev. These same two vars MUST also be set in the
# Vercel project (Settings > Environment Variables), or the production build
# inlines empty strings and the app silently loads no data.
#
# Vite inlines VITE_* into the public client bundle at BUILD time.
# Never put a private secret behind a VITE_ prefix.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>

# Server-side only - set these as Supabase secrets, NOT here and NOT in Vercel:
#   supabase secrets set ANTHROPIC_API_KEY=...   (used by functions/claude-proxy)
#   supabase secrets set GOOGLE_MAPS_KEY=...     (used by functions/distance-matrix)
